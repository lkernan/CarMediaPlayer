<?xml version="1.0" encoding="utf-8"?>
<!-- Dark card with a centred music-note icon — shown when no album art is available -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background fill -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_card"/>
        </shape>
    </item>

    <!-- Music note vector, centred, 40 % of the view size -->
    <item
        android:gravity="center"
        android:width="48dp"
        android:height="48dp">
        <vector
            android:width="48dp"
            android:height="48dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="@color/text_hint"
                android:pathData="M12,3v10.55c-0.59-0.34-1.27-0.55-2-0.55c-2.21,0-4,1.79-4,4s1.79,4,4,4s4-1.79,4-4V7h4V3H12z"/>
        </vector>
    </item>

</layer-list>
