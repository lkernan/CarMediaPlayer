<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ── Source / nav bar ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/top_bar_height"
        android:orientation="horizontal"
        android:background="@color/top_bar_bg"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_md">

        <!-- Source tabs -->
        <Button
            android:id="@+id/btn_source_usb1"
            style="@style/SourceTabButton"
            android:text="@string/source_usb1"/>

        <Button
            android:id="@+id/btn_source_online"
            style="@style/SourceTabButton"
            android:text="@string/source_online"/>

        <Button
            android:id="@+id/btn_source_bt"
            style="@style/SourceTabButton"
            android:text="@string/source_bt"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Now Playing pill -->
        <Button
            android:id="@+id/btn_now_playing"
            style="@style/NowPlayingButton"
            android:text="@string/now_playing"
            android:drawableStart="@drawable/ic_play"
            android:drawablePadding="@dimen/spacing_sm"/>

    </LinearLayout>

    <!-- ── Content (browse or now playing) ──────────────────────────── -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- ── Mini player divider + bar ───────────────────────────────── -->
    <View
        android:id="@+id/mini_player_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/mini_player"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mini_player_height"
        android:orientation="horizontal"
        android:background="@color/mini_player_bg"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/mini_album_art"
            android:layout_width="@dimen/mini_player_thumb"
            android:layout_height="@dimen/mini_player_thumb"
            android:scaleType="centerCrop"
            android:background="@color/bg_card"
            android:contentDescription="@null"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_md">

            <TextView
                android:id="@+id/mini_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/mini_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/mini_btn_previous"
            android:layout_width="@dimen/mini_player_btn"
            android:layout_height="@dimen/mini_player_btn"
            android:padding="@dimen/spacing_sm"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/text_primary"
            android:contentDescription="Previous"/>

        <ImageButton
            android:id="@+id/mini_btn_play_pause"
            android:layout_width="@dimen/mini_player_btn"
            android:layout_height="@dimen/mini_player_btn"
            android:padding="@dimen/spacing_sm"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play"
            android:tint="@color/accent"
            android:contentDescription="Play / Pause"/>

        <ImageButton
            android:id="@+id/mini_btn_next"
            android:layout_width="@dimen/mini_player_btn"
            android:layout_height="@dimen/mini_player_btn"
            android:padding="@dimen/spacing_sm"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/text_primary"
            android:contentDescription="Next"
            android:layout_marginEnd="@dimen/spacing_md"/>

    </LinearLayout>

</LinearLayout>
