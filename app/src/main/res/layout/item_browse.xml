<?xml version="1.0" encoding="utf-8"?>
<!-- Unified row for artists, albums, and tracks -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/browse_item_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/spacing_md"
    android:background="?attr/selectableItemBackground">

    <!-- Thumbnail / icon -->
    <ImageView
        android:id="@+id/item_thumb"
        android:layout_width="@dimen/browse_item_thumb"
        android:layout_height="@dimen/browse_item_thumb"
        android:scaleType="centerCrop"
        android:background="@color/bg_card"
        android:contentDescription="@null"/>

    <!-- Title + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:id="@+id/item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_md"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Chevron — only visible for browsable (folder) items -->
    <ImageView
        android:id="@+id/item_chevron"
        android:layout_width="@dimen/item_chevron_size"
        android:layout_height="@dimen/item_chevron_size"
        android:src="@drawable/ic_skip_next"
        android:tint="@color/text_hint"
        android:scaleX="0.6"
        android:scaleY="0.6"
        android:contentDescription="@null"
        android:visibility="gone"/>

</LinearLayout>
