<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/widget_bg"
    android:gravity="center"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/widget_text_size"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/widget_text_size"/>

    <!-- Transport row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@null"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/text_primary"
            android:contentDescription="Previous"/>

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@null"
            android:src="@drawable/ic_play"
            android:tint="@color/accent"
            android:contentDescription="Play / Pause"/>

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@null"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/text_primary"
            android:contentDescription="Next"/>

    </LinearLayout>

    <!-- Source row -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_source_prev"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@null"
            android:src="@drawable/ic_skip_previous"
            android:tint="@color/text_secondary"
            android:contentDescription="Previous source"/>

        <ImageButton
            android:id="@+id/btn_source_next"
            android:layout_width="@dimen/widget_btn_size"
            android:layout_height="@dimen/widget_btn_size"
            android:background="@null"
            android:src="@drawable/ic_skip_next"
            android:tint="@color/text_secondary"
            android:contentDescription="Next source"/>

    </LinearLayout>

</LinearLayout>
