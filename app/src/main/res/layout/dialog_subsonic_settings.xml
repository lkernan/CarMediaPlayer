<?xml version="1.0" encoding="utf-8"?>
<!-- Settings dialog for the Subsonic / Navidrome server connection. -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_sm">

        <!-- Server URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subsonic_label_url"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/text_sm"/>

        <EditText
            android:id="@+id/edit_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:hint="@string/subsonic_hint_url"
            android:inputType="textUri"
            android:textSize="@dimen/text_md"
            android:maxLines="1"/>

        <!-- Username -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subsonic_label_username"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/text_sm"/>

        <EditText
            android:id="@+id/edit_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:inputType="text"
            android:textSize="@dimen/text_md"
            android:maxLines="1"/>

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subsonic_label_password"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="@dimen/text_sm"/>

        <EditText
            android:id="@+id/edit_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textSize="@dimen/text_md"
            android:maxLines="1"/>

    </LinearLayout>

</ScrollView>
