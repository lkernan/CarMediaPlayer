<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <!-- Suppress the activity transition animation so theme recreation is instant -->
        <item name="android:windowAnimationStyle">@null</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>

    <!-- Source tab buttons in the top bar -->
    <style name="SourceTabButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:minWidth">@dimen/source_btn_min_width</item>
        <item name="android:minHeight">@dimen/top_bar_height</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingHorizontal">@dimen/spacing_md</item>
    </style>

    <!-- Category buttons in the browse sidebar -->
    <style name="CategoryButton" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/sidebar_btn_min_height</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingHorizontal">@dimen/spacing_md</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_md</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Selected state for category + source buttons -->
    <style name="CategoryButton.Selected">
        <item name="android:textColor">@color/accent</item>
        <item name="android:backgroundTint">@color/accent_dim</item>
    </style>

    <!-- Now Playing pill button -->
    <style name="NowPlayingButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">@dimen/sidebar_back_min_height</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:backgroundTint">@color/accent</item>
        <item name="android:paddingHorizontal">@dimen/spacing_md</item>
    </style>
</resources>
